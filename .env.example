# Syncora Panel - ornek ortam ayarlari
# Gercek kullanim icin bu dosyayi .env olarak kopyalayip gizli degerleri doldur.
APP_URL=https://syncora.netlify.app
SITE_URL=https://syncora.netlify.app
BASE_URL=https://syncora.netlify.app
PUBLIC_SITE_URL=https://syncora.netlify.app
API_BASE_URL=/api
SYNCORA_STORAGE=netlify-blobs
SYNCORA_AUTH_STORAGE=netlify-blobs
# Netlify Blobs modu aktif: phpMyAdmin/MySQL gerekmez.
# Eski MySQL adapteri sadece SYNCORA_AUTH_STORAGE=mysql yazilirsa manuel calisir.
DATA_DIR=data
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://syncora.netlify.app/discord/callback
DISCORD_BOT_TOKEN=
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=Syncora
MAIL_ENCRYPTION=tls
GMAIL_USER=
GMAIL_APP_PASSWORD=
SYNCORA_AUTH_TABLE=member
SYNCORA_PASSWORD_RESETS_TABLE=password_resets
SYNCORA_AUTH_ID_COLUMN=id
SYNCORA_AUTH_NAME_COLUMN=name
SYNCORA_AUTH_EMAIL_COLUMN=email
SYNCORA_AUTH_PASSWORD_COLUMN=password_hash
SYNCORA_LOGIN_PATH=index.html
TOKEN_SECRET=
FIVEM_SERVER=
FIVEM_SERVER_NAME=Syncora